{
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 4,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.json", "*.jsonc", "*.yml", "*.yaml", "*.md"],
            "options": { "tabWidth": 2 }
        },
        {
            "files": ["*.css"],
            "options": { "singleQuote": false }
        }
    ]
}
