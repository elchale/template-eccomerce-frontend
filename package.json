{
  "name": "ecommerce-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "knip:strict": "knip --strict",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "validate": "run-p -l --aggregate-output typecheck lint stylelint format:check knip test",
    "validate:ci": "npm-run-all -l -s typecheck lint stylelint format:check knip test build",
    "validate:full": "npm-run-all -l -s typecheck lint stylelint format:check knip test build e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@lyracom/embedded-form-glue": "^1.4.4",
    "@phosphor-icons/react": "^2.1.7",
    "@react-oauth/google": "^0.13.4",
    "@sentry/react": "^10.52.0",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-devtools": "^5.85.3",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.11.0",
    "chart.js": "^4.4.8",
    "dompurify": "^3.4.2",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "jwt-decode": "^4.0.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^8.1.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.5.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.15.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.12.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.5",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "stylelint": "^17.11.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  }
}
