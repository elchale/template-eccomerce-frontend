# Normalize all text files to LF in the repo. Linux CI runs Prettier with
# `endOfLine: "lf"` — any CRLF in committed source files fails the check.
# Setting eol=lf at the repo level lets Windows contributors keep CRLF in
# their working tree (via autocrlf) while storage stays LF.
* text=auto eol=lf

# Husky hooks and shell scripts MUST stay LF on every platform.
# Without this, Git's autocrlf=true on Windows converts them to CRLF,
# which breaks `Exec format error` on the pre-commit hook.
.husky/** text eol=lf
*.sh text eol=lf

# Treat known binary formats so git never tries to diff or convert them.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# Lockfile stays LF — npm rewrites it on each install and CRLF here
# would create spurious diffs across Windows/Linux contributors.
package-lock.json text eol=lf
