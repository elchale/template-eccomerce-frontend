# =========================================
# LOCAL DEVELOPMENT — copy to .env
# Production values live in .env.prod (gitignored) and are pasted into
# Vercel → Settings → Environment Variables.
# =========================================

# Project name used throughout the application
VITE_PROJECT_NAME="Qolca Solutions"

# Base URL for the backend API.
#  - DEV: leave empty so axios uses same-origin and Vite's dev proxy forwards
#    /api, /auth, /static, /media, /admin, /ws to the local Django backend
#    (default http://127.0.0.1:8000; override via VITE_BACKEND_PROXY_TARGET).
#  - PROD: set to the absolute API origin, e.g. https://api-shop.testperu.com
VITE_API_URL=http://localhost:8000

# Optional — override the dev-proxy backend target (defaults to http://127.0.0.1:8000)
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# Google Identity Services Web Client ID
# Obtain from Google Cloud Console -> Credentials -> OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=

# Active payment gateway: "mercadopago" (default), "culqi" or "izipay".
# Mercado Pago is the active gateway; Culqi and Izipay are kept dormant for fallback.
VITE_PAYMENT_GATEWAY=mercadopago

# Mercado Pago public key (ACTIVE gateway). Safe to expose in the browser.
# Format: APP_USR-<key> (use the same key in test + prod; the access token
# prefix on the backend implies sandbox vs live).
# Source: MP panel (https://www.mercadopago.com.pe/developers/panel) → "Tus
# integraciones" → Credenciales.
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-ad2872fd-095f-4864-b93e-fed62450e8e1

# Culqi public key (DORMANT — only used when VITE_PAYMENT_GATEWAY=culqi).
# Format: pk_test_<key> (TEST)  or  pk_live_<key> (PROD)
# Source: CulqiPanel (https://culqipanel.culqi.com) → Desarrollo → API Keys.
# The backend returns this in the /culqi/order/ response, but it is also kept
# here for parity; the CulqiForm uses the backend-provided value.
VITE_CULQI_PUBLIC_KEY=

# Izipay / Lyra Krypton embedded form public key (DORMANT — only used when
# VITE_PAYMENT_GATEWAY=izipay).
# Format: <SHOP_ID>:testpublickey_<key>  (TEST)  or  <SHOP_ID>:publickey_<key>  (PROD)
# Source: Izipay Backoffice → Tienda → Claves → "Clave pública".
# Without this, KRGlue.loadLibrary() fails and the card form never renders.
VITE_IZIPAY_PUBLIC_KEY=

# Google Maps JS API key with the Places library enabled.
# Optional — when unset, the AddressPicker on /checkout silently degrades
# to manual entry (PE departamento dropdown + free-text). To enable the
# Temu-style autocomplete, create a key with restrictions:
#   APIs allowed: Maps JavaScript API + Places API (New)
#   Referrers allowed: https://<your-domain>/*  +  http://localhost:5174/*
VITE_GOOGLE_MAPS_API_KEY=

# Display locale + currency for formatCurrency / formatNumber.
# Defaults to es-PE / PEN if unset — only override for non-Peru deployments.
# VITE_LOCALE=es-PE
# VITE_CURRENCY=PEN

# Sentry (optional — leave empty in dev to disable client-side error tracking).
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=local
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
